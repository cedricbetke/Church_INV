{
  "scripts": {
    "dev": "concurrently -n api,client -c blue,green \"npm run dev:api\" \"npm run dev:client\"",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:client": "npm --prefix apps/client run start",
    "dev:web": "concurrently -n api,client-web -c blue,green \"npm run dev:api\" \"npm run dev:client:web\"",
    "dev:client:web": "npm --prefix apps/client run web",
    "backfill:photo-thumbs": "npx tsx scripts/backfill-photo-thumbnails.ts",
    "cleanup:photo-documents": "npx tsx scripts/cleanup-photo-documents.ts",
    "optimize:stored-photos": "npx tsx scripts/optimize-stored-photos.ts",
    "sync:pco-bookings": "npx tsx scripts/sync-pco-bookings.ts",
    "sync:pco-mappings": "npx tsx scripts/sync-pco-mappings.ts",
    "import:teams-documents": "npx tsx scripts/import-teams-documents.ts",
    "import:teams-photos": "npx tsx scripts/import-teams-photos.ts",
    "import:teams": "npx tsx scripts/import-teams-inventory.ts",
    "sync:patch-notes": "npx tsx scripts/sync-patch-notes.ts"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "playwright": "^1.55.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
