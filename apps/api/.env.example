# API-Port innerhalb des Containers
PORT=3000

# Passwort fuer Admin-Aktionen in der API und im Frontend-Admin-Login
ADMIN_PASSWORD=admin

# Datenbank-Host aus Sicht der API; im Docker-Setup ist das der Compose-Service `db`
DB_HOST=db
DB_PORT=3306

# App-User fuer MySQL; diese Werte nutzt auch der MySQL-Container zur Initialisierung
DB_USER=churchinv
DB_PASSWORD=secret
DB_NAME=church_Inv_Sql

# Separates Root-Passwort fuer MySQL-Administration und einmalige DB-Imports
MYSQL_ROOT_PASSWORD=change-me-root-password
